# Ghost Configuration Template
# Copy to .env and fill in your values
# NEVER commit .env to git!

# Ghost Blog URL
GHOST_URL=https://your-blog.com

# Ghost Admin Credentials
GHOST_ADMIN=your@email.com
GHOST_USER=your@email.com
GHOST_PASSWORD=your_ghost_admin_password

# Gmail Configuration (for 2FA code extraction)
GHOST_GMAIL_USER=your@gmail.com
# Get this from: https://myaccount.google.com/apppasswords
# Must be 16-character app password (NOT your main Gmail password)
GHOST_GMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: Google Analytics (for code injection)
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
